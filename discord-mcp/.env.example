# VoiceDrop — user OAuth only (no bot token required)
# Copy to discord-mcp/.env

DISCORD_CLIENT_ID=your_app_client_id
DISCORD_CLIENT_SECRET=your_client_secret

# Optional — defaults to http://localhost:5173/api/auth/callback in dev
# DISCORD_REDIRECT_URI=

# Optional session signing (dev default used if unset)
# SESSION_SECRET=long_random_string
