{
  "name": "postman-mcp-discord-group-chat-auto-generate-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"npm run dev:api\" \"vite\"",
    "dev:api": "node --watch server/local.js",
    "dev:web": "vite",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "preview": "vite preview",
    "mcp": "cd discord-mcp && node mcpServer.js",
    "mcp:http": "cd discord-mcp && node mcpServer.js --streamable-http"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "axios": "^1.18.1",
    "dotenv": "^17.4.2",
    "express": "^4.21.0",
    "jose": "^6.2.3",
    "lucide-react": "^1.23.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "tailwindcss": "^4.3.2"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "oxlint": "^1.72.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1"
  }
}
